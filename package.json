{
  "scripts": {
    "build:css": "postcss src/styles.css -o assets/css/styles.css",
    "build:editor": "postcss src/editor.css -o assets/css/editor.css",
    "build:blocks": "postcss src/css/blocks/*.css --dir assets/css/blocks",
    "build": "npm run build:css && npm run build:editor && npm run build:blocks",
    "start": "postcss src/styles.css -o assets/css/styles.css --watch",
    "watch:css":    "postcss src/styles.css -o assets/css/styles.css --watch",
    "watch:blocks": "postcss src/css/blocks/*.css --dir assets/css/blocks --watch"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.0",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.0.0",
    "cssnano": "^7.0.0"
  }
}