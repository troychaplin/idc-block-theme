{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Thin Lines: Blue",
	"slug": "thin-lines-blue",
	"blockTypes": ["core/paragraph"],
	"styles": {
		"typography": {
            "fontFamily": "var(--wp--preset--font-family--inter)",
			"fontSize": "var(--wp--preset--font-size--small)",
            "fontStyle": "italic",
            "fontWeight": "200"
		},
		"color": {
            "text": "var(--wp--preset--color--primary-pale)"
        },
        "spacing": {
            "margin": {
                "bottom": "var(--wp--preset--spacing--70)"
            }
        }
	}
}
